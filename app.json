{
  "expo": {
    "name": "FoodoraX",
    "slug": "foodorax",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foodorax.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FoodoraX uses your location to find nearby restaurants and track deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FoodoraX uses your location in the background to provide real-time delivery tracking.",
        "NSCameraUsageDescription": "FoodoraX uses your camera to upload restaurant photos and profile pictures.",
        "NSPhotoLibraryUsageDescription": "FoodoraX accesses your photo library to upload images."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY_IOS"
      }
    },
    "android": {
      "package": "com.foodorax.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_ANDROID"
        }
      }
    },
    "web": {},
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#FF6B35"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FoodoraX to use your location.",
          "locationWhenInUsePermission": "Allow FoodoraX to use your location.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload restaurant images.",
          "cameraPermission": "The app accesses your camera to take photos."
        }
      ],
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.foodorax",
          "enableGooglePay": true
        }
      ],
      "expo-asset"
    ],
    "scheme": "foodorax"
  }
}
