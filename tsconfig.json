{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@src/*": [
        "src/*"
      ],
      "@store/*": [
        "src/store/*"
      ],
      "@library/*": [
        "src/library/*"
      ],
      "@config/*": [
        "src/config/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@routes/*": [
        "src/routes/*"
      ],
      "@stacks/*": [
        "src/stacks/*"
      ],
      "@assets/*": [
        "assets/*"
      ],
      "@colors": [
        "src/colors"
      ],
      "@fonts": [
        "src/fonts"
      ]
    },
    "noCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase"
  ]
}
